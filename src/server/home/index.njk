{% extends 'layouts/page.njk' %}

{% block content %}
  {{ appHeading({
    text: heading
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <p class="govuk-body">
        This is a demonstration of the <strong>forms-engine-plugin</strong>, a Hapi.js plugin for
        rendering and processing GOV.UK-style forms.
      </p>
      <p class="govuk-body">
        Two example forms are available from the navigation bar above:
      </p>
      <ul class="govuk-list govuk-list--bullet">
        <li>
          <strong>Simple form</strong> — a minimal form with a single text input, demonstrating
          the basic setup required to get a form rendering end-to-end.
        </li>
        <li>
          <strong>Register a unicorn form</strong> — a more complex, multi-page form with
          conditional routing, multiple field types, and a summary page.
        </li>
      </ul>
    </div>
  </div>
{% endblock %}
